{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "NotebookEdit",
      "WebFetch",
      "WebSearch",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(ls:*)",
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Bash(yarn run:*)",
      "Bash(yarn test:*)",
      "Bash(bun run:*)",
      "Bash(bun test:*)",
      "Bash(go test:*)",
      "Bash(go build:*)",
      "Bash(make:*)",
      "Bash(just:*)",
      "mcp__fff__ffgrep",
      "mcp__fff__fffind",
      "mcp__fff__fff-multi-grep",
      "Read(*.env.llm)",
      "Read(*.envrc)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push:*)",
      "Bash(but push:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(sudo:*)",
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.*.local)",
      "Read(.env.development)",
      "Read(.env.production)",
      "Read(.env.staging)",
      "Read(.env.test)"
    ]
  },
  "model": "opus",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -cr '# pbtk-prehook-v3\n{hookSpecificOutput:{hookEventName:\"PreToolUse\",updatedInput:(.tool_input + {command:\n  (\"pbtk exec --shell -- \" + (.tool_input.command | @sh))})}}'"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "pb@pb-skills": true,
    "revdiff@revdiff": true
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "autoMemoryEnabled": false,
  "skipWorkflowUsageWarning": true,
  "voiceEnabled": true,
  "attributionEnabled": false,
  "attributionName": "",
  "mcpServers": {
    "fff": {
      "command": "fff-mcp",
      "args": []
    }
  },
  "tui": "fullscreen"
}
